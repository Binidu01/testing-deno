{
  "imports": {
    "hono": "https://deno.land/x/hono@v4.3.11/mod.ts"
  },
  "tasks": {
    "build": "vite build",
    "postbuild": "deno run --allow-read --allow-write -e \"const f=await Deno.readTextFile('server/index.ts');await Deno.writeTextFile('server/index.ts',f.replace(/app\\.route\\('\\/',/g,'app.route(\\'/api\\','))\"",
    "start": "deno run --allow-net --allow-read --allow-env server/index.ts"
  }
}
